{
  "name": "@emuz/source",
  "version": "0.0.0",
  "license": "GPL-3.0",
  "private": true,
  "description": "EmuZ - Cross-platform emulator frontend",
  "repository": {
    "type": "git",
    "url": "https://github.com/bczy/emuz.git"
  },
  "scripts": {
    "build": "nx run-many -t build --all",
    "test": "nx run-many -t test --all",
    "test:coverage": "nx run-many -t test --all --coverage",
    "test:watch": "nx run-many -t test --all --watch",
    "lint": "nx run-many -t lint --all",
    "fix": "nx run-many -t lint --all --fix && prettier --write .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "graph": "nx graph",
    "affected": "nx affected",
    "affected:build": "nx affected -t build",
    "affected:test": "nx affected -t test",
    "affected:lint": "nx affected -t lint"
  },
  "devDependencies": {
    "@nx/eslint": "^22.3.3",
    "@nx/eslint-plugin": "^22.3.3",
    "@nx/js": "^22.3.3",
    "@nx/react": "^22.3.3",
    "@nx/react-native": "^22.3.3",
    "@nx/vite": "^22.3.3",
    "@nx/web": "22.3.3",
    "@swc-node/register": "~1.9.1",
    "@swc/core": "~1.13.3",
    "@swc/helpers": "~0.5.11",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^4.0.16",
    "@vitest/ui": "^4.0.0",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^10.0.1",
    "husky": "^9.1.7",
    "jiti": "2.4.2",
    "jsdom": "^27.1.0",
    "jsonc-eslint-parser": "^2.1.0",
    "lint-staged": "^16.2.7",
    "nx": "^22.3.3",
    "prettier": "~3.6.2",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.51.0",
    "vite": "^7.0.0",
    "vite-plugin-dts": "~4.5.0",
    "vitest": "^4.0.0"
  },
  "packageManager": "pnpm@9.15.2",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "i18next": "^24.2.0",
    "react": "18.3.1",
    "react-i18next": "^15.4.0",
    "zod": "^3.24.1"
  }
}
