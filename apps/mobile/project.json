{
  "name": "mobile",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/mobile/src",
  "projectType": "application",
  "tags": ["scope:app", "platform:mobile"],
  "targets": {
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "react-native start",
        "cwd": "apps/mobile"
      }
    },
    "run-ios": {
      "executor": "nx:run-commands",
      "options": {
        "command": "react-native run-ios",
        "cwd": "apps/mobile"
      }
    },
    "run-android": {
      "executor": "nx:run-commands",
      "options": {
        "command": "react-native run-android",
        "cwd": "apps/mobile"
      }
    },
    "build-ios": {
      "executor": "nx:run-commands",
      "options": {
        "command": "react-native bundle --platform ios --entry-file index.js --bundle-output ios/main.jsbundle --assets-dest ios",
        "cwd": "apps/mobile"
      }
    },
    "build-android": {
      "executor": "nx:run-commands",
      "options": {
        "command": "react-native bundle --platform android --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res",
        "cwd": "apps/mobile"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["apps/mobile/**/*.{ts,tsx,js,jsx}"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/apps/mobile"],
      "options": {
        "jestConfig": "apps/mobile/jest.config.js",
        "passWithNoTests": true
      }
    },
    "pod-install": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd ios && pod install",
        "cwd": "apps/mobile"
      }
    }
  }
}
